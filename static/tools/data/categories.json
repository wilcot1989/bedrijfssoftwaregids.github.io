{
  "crm": {
    "title": "CRM Software",
    "slug": "crm",
    "wizard": {
      "questions": [
        {
          "id": "team_size",
          "type": "select",
          "label": "Teamgrootte",
          "options": [
            "1-2",
            "3-10",
            "11-50",
            "50+"
          ]
        },
        {
          "id": "budget",
          "type": "select",
          "label": "Budget per gebruiker per maand",
          "options": [
            "<€20",
            "€20-€50",
            "€50-€100",
            "€100+"
          ]
        },
        {
          "id": "marketing_automation",
          "type": "bool",
          "label": "Marketing automation nodig?"
        },
        {
          "id": "pipeline",
          "type": "bool",
          "label": "Sales pipeline (deals) nodig?"
        },
        {
          "id": "integrations",
          "type": "multi",
          "label": "Belangrijke integraties",
          "options": [
            "Google Workspace",
            "Microsoft 365",
            "Exact",
            "Moneybird",
            "Slack",
            "Zapier"
          ]
        }
      ]
    },
    "matrix": {
      "filters": [
        "pricing_band",
        "nl_support",
        "marketing_automation",
        "pipeline",
        "integrations"
      ]
    },
    "calculator": {
      "enabled": true,
      "type": "per_user_monthly"
    },
    "advanced": {
      "enabled": true,
      "type": "crm_roi",
      "page": "roi-berekenen/",
      "title": "CRM ROI berekenen"
    }
  },
